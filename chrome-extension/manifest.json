{
  "manifest_version": 3,
  "name": "SCG Timer → Kleer",
  "version": "1.1",
  "description": "Sync time entries from SCG Timer to Kleer",
  "permissions": ["declarativeContent"],
  "host_permissions": [
    "https://my.kleer.se/*",
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*"
  ],
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Sync SCG Timer to Kleer",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://my.kleer.se/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}
