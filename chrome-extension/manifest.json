{
  "manifest_version": 3,
  "name": "SCG Timer → Kleer",
  "version": "1.1",
  "description": "Sync time entries from SCG Timer to Kleer",
  "permissions": ["declarativeContent"],
  "host_permissions": [
    "https://my.kleer.se/*",
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Sync SCG Timer to Kleer"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://my.kleer.se/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}
